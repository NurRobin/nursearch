{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nursearch.dev/plugin-manifest.schema.json",
  "title": "NurSearch plugin manifest",
  "description": "Schema for nursearch-plugin.toml (expressed as JSON for tooling).",
  "type": "object",
  "required": ["id", "name", "protocol_version", "entry"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "description": "Unique id, reverse-DNS recommended" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "icon": { "type": "string", "description": "Themed icon name or absolute path" },
    "protocol_version": { "type": "integer", "const": 1 },
    "entry": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Command + args; launched with cwd = the plugin directory"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": ["clipboard", "open", "run", "toast", "storage"]
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["global", "keyword"] },
        "keyword": { "type": "string" },
        "fallback": { "type": "boolean" }
      },
      "if": { "properties": { "mode": { "const": "keyword" } } },
      "then": { "required": ["keyword"] }
    },
    "preferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["text", "password", "number", "select", "checkbox"] },
          "label": { "type": "string" },
          "default": {},
          "options": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
